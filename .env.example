# OptiCast AI — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit the real .env to git

# ── Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opticast_db
DB_USER=opticast
DB_PASSWORD=opticast_secret

# ── ERA5 / Copernicus CDS ─────────────────
# Get your key from: https://cds.climate.copernicus.eu/user/register
# Leave blank to use synthetic mock data (works for demo/hackathon)
CDS_URL=https://cds.climate.copernicus.eu/api/v2
CDS_KEY=
